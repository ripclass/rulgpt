APP_NAME=RuleGPT API
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rulegpt
SECRET_KEY=dev-secret-key-change-in-production

API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173","https://www.rulgpt.com","https://rulgpt.com","https://www.tfrules.com","https://tfrules.com"]
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)*vercel\.app$|^https://([a-z0-9-]+\.)?rulgpt\.com$|^https://([a-z0-9-]+\.)?tfrules\.com$

FREE_TIER_MONTHLY_LIMIT=5
PROFESSIONAL_TIER_MONTHLY_LIMIT=500
ENTERPRISE_TIER_MONTHLY_LIMIT=2000

RATE_LIMIT_PER_MIN_ANON=30
RATE_LIMIT_PER_MIN_AUTH=120

ANTHROPIC_API_KEY=
RULEGPT_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
RULEGPT_GENERATOR_MODEL=claude-sonnet-4-6
RULEGPT_COMPLEX_MODEL=claude-sonnet-4-6

RULEGPT_ENABLE_SMART_ROUTING=true
RULEGPT_TEMPLATE_ENGINE_ENABLED=true
RULEGPT_HAIKU_MODEL=claude-haiku-4-5-20251001
RULEGPT_OPUS_MODEL=claude-opus-4-6

OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=RuleGPT
RULEGPT_EMBEDDING_MODEL=text-embedding-3-small
RULEGPT_FALLBACK_MODEL=gpt-4.1

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=

RULHUB_API_URL=https://api.rulhub.com
RULHUB_API_KEY=
# Pin RulHub Architecture v2 contract date. Without it the server falls back
# to the API key's creation date — explicit beats implicit. Use rh_test_*
# keys in staging/CI (free, sandbox-tagged); ak_* / rh_live_* in production.
RULHUB_API_VERSION=2026-04-28
RULEGPT_LOCAL_RULES_ROOT=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PROFESSIONAL_MONTHLY_PRICE_ID=
STRIPE_PROFESSIONAL_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=

ADMIN_SECRET=
